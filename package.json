{
  "name": "lorume",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "dev:backend": "tsx src/backend/backend-server.ts",
    "dev:e2e": "tsx scripts/dev-e2e.ts",
    "db:up": "docker compose up -d postgres",
    "db:migrate": "node scripts/db-migrate.mjs",
    "build": "tsc -b && vite build",
    "build:backend": "vite build --config vite.backend.config.ts",
    "start:backend": "node dist/backend/backend-server.mjs",
    "setup:git-hooks": "git config core.hooksPath .githooks",
    "setup:e2e": "playwright install chromium",
    "verify": "./scripts/verify.sh",
    "check": "npm run verify",
    "check:full": "npm run verify",
    "check:commit-message": "vitest run scripts/check-commit-message.test.mjs",
    "check:repo": "./scripts/check-repo.sh",
    "check:backend": "vitest run src/auth/auth-crypto.test.ts src/auth/auth-http-api.test.ts src/backend src/server src/operations src/notifications src/runtime/device-collector-script.test.ts",
    "check:backend:standalone": "vitest run src/backend",
    "check:db": "npm run db:up && LORUME_RUN_DB_TESTS=1 LORUME_TEST_DATABASE_URL=postgres://lorume:lorume@127.0.0.1:54329/postgres vitest run src/auth/auth-store.test.ts src/server/db-migrate.test.ts src/server/postgres-store.test.ts src/server/runtime-http-api-postgres.test.ts src/backend/backend-server.test.ts src/operations/operation-store.test.ts src/notifications/notification-store.test.ts",
    "check:runtime": "vitest run src/runtime",
    "check:quick": "npm run typecheck && npm run test:run",
    "check:build": "npm run build",
    "check:deploy": "npm run build:backend && node scripts/check-deploy-config.mjs",
    "smoke:production": "node scripts/smoke-production.mjs",
    "check:e2e": "npm run test:e2e",
    "harness": "npm run check:full",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest",
    "test:run": "vitest run",
    "test:e2e": "env -u NO_COLOR playwright test",
    "test:e2e:install": "npm run setup:e2e"
  },
  "dependencies": {
    "@types/ws": "^8.18.1",
    "nodemailer": "^8.0.7",
    "pg": "^8.20.0",
    "pixelarticons": "^2.1.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.19.18",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "jsdom": "^29.1.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.11",
    "vitest": "^4.1.5"
  }
}
