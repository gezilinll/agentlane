FROM node:22-alpine AS deps
WORKDIR /app
COPY package.json package-lock.json ./
RUN npm ci

FROM deps AS build
COPY . .
RUN npm run build:backend

FROM node:22-alpine AS runtime
WORKDIR /app
ENV NODE_ENV=production
ENV AGENTLANE_BACKEND_HOST=0.0.0.0
ENV AGENTLANE_BACKEND_PORT=4173
COPY package.json package-lock.json ./
RUN npm ci --omit=dev && npm cache clean --force
COPY --from=build /app/dist/backend ./dist/backend
COPY db ./db
COPY scripts/db-migrate.mjs ./scripts/db-migrate.mjs
EXPOSE 4173
CMD ["sh", "-c", "node scripts/db-migrate.mjs && node dist/backend/backend-server.mjs"]
